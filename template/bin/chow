#!/usr/bin/env bash
#
# chow — Launch an agent session with a generated system prompt.
#
# Reads lane-specific memory, builds a combined prompt via
# build-prompt.mjs, then launches pi with the appropriate model
# flags, tools, and session directory.
#
# Environment variables (all optional):
#   CHOW_LANE          Lane name (chow|hector|terminal-chow)
#   CHOW_CLI_MODEL     CLI agent model (default: opencode-go/deepseek-v4-pro)
#   CHOW_WORKER_MODEL  Worker model (default: opencode-go/deepseek-v4-flash)
#
# Flags:
#   --dsflashmode     Enable deep-search flash mode (sets DSFLASHMODE=1)
#   --manager-mode    Enable manager-mode tools (subagent, intercom, ...)
#   --lane <name>     Override CHOW_LANE
#
set -euo pipefail

# --- Paths ----------------------------------------------------------------
PI_BIN="$(command -v pi 2>/dev/null || true)"
if [[ -z "$PI_BIN" ]]; then
  for try in /usr/local/bin/pi ~/.local/bin/pi ~/.pi/pi; do
    [[ -x "$try" ]] && { PI_BIN="$try"; break; }
  done
fi

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
TEMPLATE_DIR="$(cd "$SCRIPT_DIR/../chow" 2>/dev/null && pwd || echo "$SCRIPT_DIR/../chow")"

PROMPT_BUILDER="${TEMPLATE_DIR}/build-prompt.mjs"
SESSION_DIR="${HOME}/.pi/agent/chow-memory-v2"
GENERATED_PROMPT="${SESSION_DIR}/SYSTEM.generated.md"
AUTH_FILE="${SESSION_DIR}/auth.json"

# --- Defaults --------------------------------------------------------------
CHOW_CLI_MODEL="${CHOW_CLI_MODEL:-opencode-go/deepseek-v4-pro}"
CHOW_WORKER_MODEL="${CHOW_WORKER_MODEL:-opencode-go/deepseek-v4-flash}"
LANE="${CHOW_LANE:-chow}"
DSFLASHMODE=0
MANAGER_MODE=0

# --- Usage -----------------------------------------------------------------
usage() {
  cat <<'USAGE_EOF'
Usage: chow [options]

Launch an agent session with a lane-specific system prompt built from
memory files and checkpoints.

Options:
  --help             Show this help text and exit.
  --dsflashmode      Enable deep-search flash mode (DSFLASHMODE=1).
  --manager-mode     Enable manager-mode tools (subagent, intercom,
                     switch_model, pi_messenger, analyze_image,
                     structured_return, review_loop).
  --lane <name>      Lane to use (chow|hector|terminal-chow).

Environment:
  CHOW_LANE         Lane override (default: chow).
  CHOW_CLI_MODEL    CLI model (default: opencode-go/deepseek-v4-pro).
  CHOW_WORKER_MODEL Worker model (default: opencode-go/deepseek-v4-flash).

Lanes:
  chow          Mr Chow terminal agent - friendly, contextual, memory-rich.
  hector        Dell WSL2 GPU agent - performance-focused, hardware-aware.
  terminal-chow Isolated terminal - minimal personality, clean slate.

Examples:
  chow                        # default lane
  chow --dsflashmode          # deep-search flash mode
  chow --manager-mode         # orchestration tools
  chow --lane hector          # Dell WSL2 lane
  CHOW_LANE=terminal-chow chow
USAGE_EOF
}

# --- Parse flags -----------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage; exit 0 ;;
    --dsflashmode)
      DSFLASHMODE=1; shift ;;
    --manager-mode)
      MANAGER_MODE=1; shift ;;
    --lane)
      if [[ $# -lt 2 ]]; then
        echo "ERROR: --lane requires an argument" >&2; exit 1
      fi
      LANE="$2"; shift 2 ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage >&2; exit 1 ;;
  esac
done

# --- Validate lane ---------------------------------------------------------
case "$LANE" in
  chow|hector|terminal-chow) ;;
  *)
    echo "ERROR: Invalid lane '$LANE'. Must be one of: chow, hector, terminal-chow." >&2
    exit 1 ;;
esac

# --- Read auth file and export API key env vars ----------------------------
# The auth file is a key=value store. Each recognized key sets an
# environment variable that pi uses for credential resolution.
if [[ -f "$AUTH_FILE" ]]; then
  while IFS='=' read -r key value; do
    # Skip blank lines and comments
    [[ -z "$key" || "$key" == '#'* ]] && continue
    # Trim leading/trailing whitespace
    key="$(echo "$key" | xargs)"
    value="$(echo "$value" | xargs)"
    case "$key" in
      OPENCODE_GO_API_KEY|OPencode_GO_key|opencode-go)
        export OPENCODE_GO_API_KEY="$value" ;;
      OPENCODE_ZEN2_API_KEY|OPencode_ZEN2_key|opencode-zen2)
        export OPENCODE_ZEN2_API_KEY="$value" ;;
      OPENCODE_ZEN3_API_KEY|OPencode_ZEN3_key|opencode-zen3)
        export OPENCODE_ZEN3_API_KEY="$value" ;;
      OPENCODE_ZEN4_API_KEY|OPencode_ZEN4_key|opencode-zen4)
        export OPENCODE_ZEN4_API_KEY="$value" ;;
      OPENROUTER_API_KEY|OPENROUTER_key|openrouter)
        export OPENROUTER_API_KEY="$value" ;;
      OLLAMA_API_KEY|OLLAMA_key|ollama)
        export OLLAMA_API_KEY="$value" ;;
      OLLAMA2_API_KEY|OLLAMA2_key|ollama2)
        export OLLAMA2_API_KEY="$value" ;;
    esac
  done < "$AUTH_FILE"
fi

# --- Ensure session dir exists ---------------------------------------------
mkdir -p "$SESSION_DIR"

# --- Assemble model flags -------------------------------------------------
MODEL_FLAGS=(--model "$CHOW_CLI_MODEL" --worker-model "$CHOW_WORKER_MODEL")
if [[ "$DSFLASHMODE" -eq 1 ]]; then
  MODEL_FLAGS+=(--dsflashmode)
fi

# --- Tools list ------------------------------------------------------------
if [[ "$MANAGER_MODE" -eq 1 ]]; then
  # Manager mode: high-level orchestration tools only — agent spawning,
  # inter-agent messaging, model switching, analysis, structured returns.
  TOOLS="--tools subagent,intercom,switch_model,pi_messenger,analyze_image,structured_return,review_loop"
else
  # Full default tool set — all editing, browsing, memory, inter-agent
  # communication, supervisor contact, and notification capabilities.
  TOOLS="--tools bash,file_editor,read,write,edit,grep,glob,gather,web_fetch,memory,intercom,contact_supervisor,notify,structured_return,review_loop,pi_messenger,analyze_image"
fi

# --- Build system prompt via build-prompt.mjs ------------------------------
if [[ ! -f "$PROMPT_BUILDER" ]]; then
  echo "ERROR: Prompt builder not found at $PROMPT_BUILDER" >&2
  exit 1
fi

# Export context for the Node.js builder
export CHOW_LANE="$LANE"
export DSFLASHMODE
export MANAGER_MODE

BUILDER_FLAGS=(--write "$GENERATED_PROMPT")
if [[ "$MANAGER_MODE" -eq 1 ]]; then
  BUILDER_FLAGS+=(--manager-mode)
fi

echo "=== chow: Building prompt for lane '$LANE' ===" >&2
if ! node "$PROMPT_BUILDER" "${BUILDER_FLAGS[@]}"; then
  echo "ERROR: Prompt builder failed." >&2
  exit 1
fi
if [[ ! -f "$GENERATED_PROMPT" ]]; then
  echo "ERROR: Prompt builder did not produce $GENERATED_PROMPT" >&2
  exit 1
fi

# --- Checkpoint handling ---------------------------------------------------
CHECKPOINT_FILE="${SESSION_DIR}/checkpoints/latest.md"
SESSION_ARGS=()
if [[ -f "$CHECKPOINT_FILE" && -s "$CHECKPOINT_FILE" ]]; then
  SESSION_ARGS+=(--checkpoint "$CHECKPOINT_FILE")
fi

# --- Launch pi -------------------------------------------------------------
if [[ -z "$PI_BIN" ]]; then
  echo "ERROR: pi binary not found. Please install pi or add it to PATH." >&2
  exit 1
fi

echo "=== chow: Launching pi (lane: $LANE) ===" >&2
exec "$PI_BIN" \
  "${MODEL_FLAGS[@]}" \
  --session-dir "$SESSION_DIR" \
  $TOOLS \
  --prompt "$GENERATED_PROMPT" \
  "${SESSION_ARGS[@]}"
